# Copy this file to ".env.local" in the same folder and fill in values.
# Restart "npm run dev" after any change — Next.js reads NEXT_PUBLIC_* at startup.

# FastAPI base URL (no trailing slash). MUST match the port you run uvicorn on:
#   python -m uvicorn app.main:app --reload --port 8000   → http://localhost:8000
#   ... --port 8080   → http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8000

# Required for /admin and /auth/callback — from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: comma-separated emails allowed to open /admin (must match Google sign-in users).
NEXT_PUBLIC_ADMIN_EMAIL_ALLOWLIST=
