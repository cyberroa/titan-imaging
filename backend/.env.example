DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres
APP_ENV=local
PORT=8000

# Comma-separated list of allowed origins for CORS.
# Example:
# CORS_ORIGINS=http://localhost:3000,https://titan-imaging.vercel.app
CORS_ORIGINS=http://localhost:3000

# Optional outbound email (Resend). If unset, emails are skipped.
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=
EMAIL_FROM=
# Customer-facing from (inventory alerts & outreach). Falls back to EMAIL_FROM / ADMIN_NOTIFY_EMAIL.
EMAIL_FROM_CUSTOMER=

# Phase 3 admin (Supabase Auth + allowlist). Required for /api/v1/admin/*.
# SUPABASE_URL — Project URL (https://xxx.supabase.co). Used for JWKS verification (JWT Signing Keys).
SUPABASE_URL=
# SUPABASE_JWT_SECRET — Legacy HS256 only; optional if you use signing keys + JWKS. Keep during migration.
SUPABASE_JWT_SECRET=
# Comma-separated admin emails (Google sign-in). If empty, API allows any authenticated user (not recommended in prod).
ADMIN_EMAIL_ALLOWLIST=

# Links in customer emails (inventory alerts). Use your public site and API URLs in production.
PUBLIC_SITE_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

# ---------- Phase 4A: campaigns, engagement, social ----------

# Resend webhooks — sign events with this shared secret (Resend → Webhooks →
# Signing secret, format "whsec_..."). Required to accept /api/v1/webhooks/resend.
RESEND_WEBHOOK_SECRET=

# Mailing address included in the CAN-SPAM footer of every customer email.
MAILING_ADDRESS=Titan Imaging, 123 Example St, Jacksonville, FL 32202

# Secret used to sign generic unsubscribe tokens in email footers.
# Pick a random value (>= 32 chars). Rotate by generating a new value (old links
# will stop working; customers can still reply to unsubscribe).
UNSUBSCRIBE_SIGNING_SECRET=

# Make scenario webhook URL for the LinkedIn composer (Webhooks → Custom webhook).
SOCIAL_WEBHOOK_URL=
# Shared secret used to sign both our outbound POST to Make and Make's callback
# to /api/v1/webhooks/social.
SOCIAL_CALLBACK_SECRET=

