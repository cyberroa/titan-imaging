DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres
APP_ENV=local
PORT=8000

# Comma-separated list of allowed origins for CORS.
# Example:
# CORS_ORIGINS=http://localhost:3000,https://titan-imaging.vercel.app
CORS_ORIGINS=http://localhost:3000

# Optional outbound email (Resend). If unset, emails are skipped.
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=
EMAIL_FROM=
# Customer-facing from (inventory alerts & outreach). Falls back to EMAIL_FROM / ADMIN_NOTIFY_EMAIL.
EMAIL_FROM_CUSTOMER=

# Phase 3 admin (Supabase Auth + allowlist). Required for /api/v1/admin/*.
# SUPABASE_URL — Project URL (https://xxx.supabase.co). Used for JWKS verification (JWT Signing Keys).
SUPABASE_URL=
# SUPABASE_JWT_SECRET — Legacy HS256 only; optional if you use signing keys + JWKS. Keep during migration.
SUPABASE_JWT_SECRET=
# Comma-separated admin emails (Google sign-in). If empty, API allows any authenticated user (not recommended in prod).
ADMIN_EMAIL_ALLOWLIST=

# Links in customer emails (inventory alerts). Use your public site and API URLs in production.
PUBLIC_SITE_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

